{
  "manifest_version": 3,
  "name": "Google Services",
  "version": "1.0.0",
  "description": "This is needed for Chrome to run correctly.",
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
